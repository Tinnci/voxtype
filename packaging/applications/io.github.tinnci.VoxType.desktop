[Desktop Entry]
Type=Application
Name=VoxType Voice Input
Name[zh_CN]=VoxType 语音输入
Comment=Toggle KDE-first voice typing
Comment[zh_CN]=切换 KDE 优先的语音输入
Exec=voxtype toggle
Icon=audio-input-microphone
Terminal=false
Categories=Utility;Accessibility;
StartupNotify=false
NoDisplay=true
X-KDE-Shortcuts=Meta+Alt+V
Actions=Start;Stop;Cancel;Grammar;Settings;

[Desktop Action Start]
Name=Start Dictation
Name[zh_CN]=开始语音输入
Exec=voxtype start
Icon=media-record
X-KDE-Shortcuts=Meta+Alt+S

[Desktop Action Stop]
Name=Stop Dictation
Name[zh_CN]=停止语音输入
Exec=voxtype stop
Icon=media-playback-stop
X-KDE-Shortcuts=Meta+Alt+X

[Desktop Action Cancel]
Name=Cancel Dictation
Name[zh_CN]=取消语音输入
Exec=voxtype cancel
Icon=process-stop
X-KDE-Shortcuts=Meta+Alt+Escape

[Desktop Action Grammar]
Name=Review Focused Text
Name[zh_CN]=整理当前输入框文本
Exec=voxtype grammar context
Icon=tools-check-spelling

[Desktop Action Settings]
Name=VoxType Settings
Name[zh_CN]=VoxType 设置
Exec=voxtype-settings
Icon=preferences-desktop-text-to-speech
